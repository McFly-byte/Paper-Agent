# 复制为 .env 后填写。勿将含真实 Key 的 .env 提交仓库。

# Ollama 服务端并发（由 ollama serve / Ollama 桌面端进程读取，非本 FastAPI 进程）
# Windows：用户环境变量 OLLAMA_NUM_PARALLEL=2，或在启动 Ollama 前执行
#   setx OLLAMA_NUM_PARALLEL 2
# 修改后需完全退出并重新启动 Ollama。
# OLLAMA_NUM_PARALLEL=2

# LangSmith 仅 Tracing：与 system_params.yaml 中 observability.langsmith 配合
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=paper-agent
